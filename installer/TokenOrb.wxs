<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product
      Id="*"
      Name="Token Orb"
      Language="2052"
      Codepage="936"
      Version="1.3.0"
      Manufacturer="chenxulin"
      UpgradeCode="{E2EE802B-B7DD-4436-ADF1-A3DF49DCD07A}">
    <Package
        InstallerVersion="500"
        Compressed="yes"
        InstallScope="perUser"
        InstallPrivileges="limited"
        Description="Token Orb v1.3 installer" />

    <MajorUpgrade
        Schedule="afterInstallInitialize"
        AllowSameVersionUpgrades="yes"
        DowngradeErrorMessage="已安装更高版本的 Token Orb，无法降级安装。" />
    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <CustomAction
        Id="SetStopTokenOrbCommand"
        Property="WixQuietExecCmdLine"
        Value="&quot;[SystemFolder]taskkill.exe&quot; /F /T /IM TokenOrb.exe"
        Execute="immediate" />
    <CustomAction
        Id="StopTokenOrbProcesses"
        BinaryKey="WixCA"
        DllEntry="WixQuietExec"
        Execute="immediate"
        Return="ignore"
        Impersonate="yes" />
    <InstallExecuteSequence>
      <Custom Action="SetStopTokenOrbCommand" Before="StopTokenOrbProcesses">
        Installed OR WIX_UPGRADE_DETECTED
      </Custom>
      <Custom Action="StopTokenOrbProcesses" Before="InstallValidate">
        Installed OR WIX_UPGRADE_DETECTED
      </Custom>
    </InstallExecuteSequence>

    <Property Id="ARPNOMODIFY" Value="1" />
    <Property Id="ARPNOREPAIR" Value="1" />
    <Property Id="DISABLEADVTSHORTCUTS" Value="1" />
    <Property Id="ARPPRODUCTICON" Value="TokenOrbIcon" />
    <Icon Id="TokenOrbIcon" SourceFile="$(var.TokenOrbIcon)" />

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="LocalAppDataFolder">
        <Directory Id="LocalProgramsFolder" Name="Programs">
          <Directory Id="INSTALLFOLDER" Name="Token Orb">
            <Component Id="TokenOrbExecutableComponent" Guid="{4BA374EF-E1D9-48DD-849D-F89C8AE2657E}">
              <File
                  Id="TokenOrbExecutable"
                  Name="TokenOrb.exe"
                  Source="$(var.TokenOrbExe)"
                  Checksum="yes" />
              <RegistryValue
                  Root="HKCU"
                  Key="Software\chenxulin\Token Orb"
                  Name="InstallPath"
                  Type="string"
                  Value="[#TokenOrbExecutable]"
                  KeyPath="yes" />
              <RemoveFolder Id="RemoveTokenOrbInstallFolder" On="uninstall" />
              <RemoveFolder
                  Id="RemoveEmptyLocalProgramsFolder"
                  Directory="LocalProgramsFolder"
                  On="uninstall" />
            </Component>
            <Component Id="TokenOrbAutoStartComponent" Guid="{86269AD8-3C73-45AA-87CE-FBB1BC5D8221}">
              <RegistryValue
                  Root="HKCU"
                  Key="Software\Microsoft\Windows\CurrentVersion\Run"
                  Name="Token Orb"
                  Type="string"
                  Value="&quot;[INSTALLFOLDER]TokenOrb.exe&quot; --watch"
                  KeyPath="yes" />
              <RemoveRegistryValue
                  Id="RemoveLegacyAutoStart"
                  Root="HKCU"
                  Key="Software\Microsoft\Windows\CurrentVersion\Run"
                  Name="CodexQuotaBall" />
            </Component>
          </Directory>
        </Directory>
      </Directory>

      <Directory Id="ProgramMenuFolder">
        <Directory Id="TokenOrbProgramMenuFolder" Name="Token Orb">
          <Component Id="TokenOrbShortcutComponent" Guid="*">
            <Shortcut
                Id="TokenOrbStartMenuShortcut"
                Name="Token Orb"
                Description="Codex quota at a glance"
                Target="[INSTALLFOLDER]TokenOrb.exe"
                WorkingDirectory="INSTALLFOLDER"
                Icon="TokenOrbIcon" />
            <RemoveFolder Id="RemoveTokenOrbProgramMenuFolder" On="uninstall" />
            <RegistryValue
                Root="HKCU"
                Key="Software\chenxulin\Token Orb"
                Name="StartMenuShortcut"
                Type="integer"
                Value="1"
                KeyPath="yes" />
          </Component>
        </Directory>
      </Directory>
    </Directory>

    <Feature Id="TokenOrbFeature" Title="Token Orb" Level="1" Absent="disallow">
      <ComponentRef Id="TokenOrbExecutableComponent" />
      <ComponentRef Id="TokenOrbAutoStartComponent" />
      <ComponentRef Id="TokenOrbShortcutComponent" />
    </Feature>
  </Product>
</Wix>
